# MongoDB Atlas connection string
# Get from Atlas → Connect → Drivers → copy the URI
# Replace <password> with your DB user password
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# MongoDB database name (leave as waveboard)
MONGODB_DB=waveboard

# Secret shared between this API and the Discord bot
# Generate a random string, e.g: openssl rand -hex 32
BOT_SECRET=your_random_secret_here
